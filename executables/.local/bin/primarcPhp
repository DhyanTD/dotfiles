#!/usr/bin/env bash

SESSION="PrimarcErpPhp"
ROOT="$HOME/Documents/Github/smoketrees/vente-erp"

# Check if session exists
tmux has-session -t $SESSION 2>/dev/null

if [ $? != 0 ]; then
  # Create session
  tmux new-session -d -s $SESSION -c "$ROOT"

  # Window: Editor
  tmux rename-window -t $SESSION:0 "Primarc Erp PHP – Editor"

  # Pane 0 → nvim
  tmux send-keys -t $SESSION:0 "nvim" C-m

  # Pane 1 → docker setup
  tmux split-window -h -t $SESSION:0 -c "$ROOT"
  tmux send-keys -t $SESSION:0.1 "docker start redis-server && docker compose up --build" C-m



  # Focus back to editor
  tmux select-pane -t $SESSION:0.0
fi

# Attach to session
tmux attach -t $SESSION
